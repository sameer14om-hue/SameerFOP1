    <div class="asgn-desc">do-while menu using strlen, strcpy, strcat, strcmp, and manual reversal. Loop repeats until user chooses Exit.</div>
  </div>
  <div class="cols">
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>C Code</span></div>
      <div class="card-body">
<pre><span class="pp">#include</span> <span class="str">&lt;stdio.h&gt;</span>
<span class="pp">#include</span> <span class="str">&lt;string.h&gt;</span>

<span class="type">int</span> <span class="fn">main</span>() {
    <span class="type">char</span> s1[<span class="num">100</span>], s2[<span class="num">100</span>];
    <span class="type">int</span>  choice, i, len;

    <span class="fn">printf</span>(<span class="str">"Enter first string : "</span>); <span class="fn">scanf</span>(<span class="str">"%s"</span>, s1);
    <span class="fn">printf</span>(<span class="str">"Enter second string: "</span>); <span class="fn">scanf</span>(<span class="str">"%s"</span>, s2);

    <span class="kw">do</span> {
        <span class="fn">printf</span>(<span class="str">"\n=== String Operations Menu ===\n"</span>);
        <span class="fn">printf</span>(<span class="str">"1. Length      (strlen)\n"</span>);
        <span class="fn">printf</span>(<span class="str">"2. Copy        (strcpy)\n"</span>);
        <span class="fn">printf</span>(<span class="str">"3. Concatenate (strcat)\n"</span>);
        <span class="fn">printf</span>(<span class="str">"4. Compare     (strcmp)\n"</span>);
        <span class="fn">printf</span>(<span class="str">"5. Reverse s1\n"</span>);
        <span class="fn">printf</span>(<span class="str">"6. Exit\n"</span>);
        <span class="fn">printf</span>(<span class="str">"Choice: "</span>); <span class="fn">scanf</span>(<span class="str">"%d"</span>, &amp;choice);

        <span class="kw">switch</span> (choice) {
            <span class="kw">case</span> <span class="num">1</span>:
                <span class="fn">printf</span>(<span class="str">"Length = %d\n"</span>, (<span class="type">int</span>)<span class="fn">strlen</span>(s1)); <span class="kw">break</span>;
            <span class="kw">case</span> <span class="num">2</span>: {
                <span class="type">char</span> copy[<span class="num">100</span>]; <span class="fn">strcpy</span>(copy, s1);
                <span class="fn">printf</span>(<span class="str">"Copied: %s\n"</span>, copy); <span class="kw">break</span>; }
            <span class="kw">case</span> <span class="num">3</span>: {
                <span class="type">char</span> cat[<span class="num">200</span>]; <span class="fn">strcpy</span>(cat, s1); <span class="fn">strcat</span>(cat, s2);
                <span class="fn">printf</span>(<span class="str">"Concatenated: %s\n"</span>, cat); <span class="kw">break</span>; }
            <span class="kw">case</span> <span class="num">4</span>:
                <span class="fn">printf</span>(<span class="fn">strcmp</span>(s1, s2) == <span class="num">0</span> ? <span class="str">"EQUAL\n"</span> : <span class="str">"NOT equal\n"</span>); <span class="kw">break</span>;
            <span class="kw">case</span> <span class="num">5</span>: {
                <span class="type">char</span> rev[<span class="num">100</span>]; len = <span class="fn">strlen</span>(s1);
                <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; len; i++) rev[i] = s1[len - <span class="num">1</span> - i];
                rev[len] = <span class="str">'\0'</span>;
                <span class="fn">printf</span>(<span class="str">"Reversed: %s\n"</span>, rev); <span class="kw">break</span>; }
            <span class="kw">case</span> <span class="num">6</span>:
                <span class="fn">printf</span>(<span class="str">"Exiting...\n"</span>); <span class="kw">break</span>;
            <span class="kw">default</span>:
                <span class="fn">printf</span>(<span class="str">"Invalid choice!\n"</span>);
        }
    } <span class="kw">while</span> (choice != <span class="num">6</span>);

    <span class="kw">return</span> <span class="num">0</span>;
}</pre>
