<!-- ==================== A16 ==================== -->
<div class="content active" id="a16">
  <div class="asgn-header">
    <div class="asgn-badge">ASSIGNMENT NO. 16</div>
    <div class="asgn-title">Partition List into Even and Odd Numbers</div>
    <div class="asgn-desc">Accept N integers and split them into two sublists — even and odd — using the modulus operator.</div>
  </div>
  <div class="cols">
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>C Code</span></div>
      <div class="card-body">
<pre><span class="pp">#include</span> <span class="str">&lt;stdio.h&gt;</span>

<span class="type">int</span> <span class="fn">main</span>() {
    <span class="type">int</span> n, i;
    <span class="fn">printf</span>(<span class="str">"Enter number of elements: "</span>);
    <span class="fn">scanf</span>(<span class="str">"%d"</span>, &amp;n);

    <span class="type">int</span> arr[n], even[n], odd[n];
    <span class="type">int</span> ec = <span class="num">0</span>, oc = <span class="num">0</span>;

    <span class="fn">printf</span>(<span class="str">"Enter %d integers: "</span>, n);
    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; n; i++)
        <span class="fn">scanf</span>(<span class="str">"%d"</span>, &amp;arr[i]);

    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; n; i++) {
        <span class="kw">if</span> (arr[i] % <span class="num">2</span> == <span class="num">0</span>)
            even[ec++] = arr[i];
        <span class="kw">else</span>
            odd[oc++] = arr[i];
    }

    <span class="fn">printf</span>(<span class="str">"\nEven numbers are: "</span>);
    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; ec; i++) <span class="fn">printf</span>(<span class="str">"%d "</span>, even[i]);

    <span class="fn">printf</span>(<span class="str">"\nOdd numbers are: "</span>);
    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; oc; i++) <span class="fn">printf</span>(<span class="str">"%d "</span>, odd[i]);

    <span class="fn">printf</span>(<span class="str">"\n"</span>);
    <span class="kw">return</span> <span class="num">0</span>;
}</pre>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="dot dot-b"></div><span>Sample I/O</span></div>
      <div class="card-body">
        <div class="output-box">
<span class="output-prompt">Input:</span><br>
Enter number of elements: 5<br>
Enter 5 integers: 10 7 4 9 12<br><br>
<span class="output-prompt">Output:</span><br>
Even numbers are: 10 4 12<br>
Odd numbers are:  7 9
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="dot dot-p"></div><span>Key Concepts</span></div>
      <div class="card-body">
        <div class="info-grid">
          <div class="info-item"><div class="info-label">Operator</div><div class="info-val">% returns remainder of division</div></div>
          <div class="info-item"><div class="info-label">Condition</div><div class="info-val">arr[i]%2==0 → Even, else Odd</div></div>
          <div class="info-item"><div class="info-label">Counters</div><div class="info-val">ec = even count, oc = odd count</div></div>
          <div class="info-item"><div class="info-label">Arrays</div><div class="info-val">Separate even[] and odd[] storage</div></div>
        </div>
      </div>
    </div>
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>Flowchart</span></div>
      <div class="card-body">
        <div class="mermaid-wrap">
          <div class="mermaid">
flowchart TD
    S([START]) --> I1[/Input N/]
    I1 --> I2[/Input arr of N integers/]
    I2 --> P1["i = 0,  ec = 0,  oc = 0"]
    P1 --> D1{"i &lt; N ?"}
    D1 -- Yes --> D2{"arr[i] % 2 == 0 ?"}
    D2 -- "Yes (Even)" --> P2["even[ec] = arr[i]&#59;  ec++"]
    D2 -- "No  (Odd)"  --> P3["odd[oc]  = arr[i]&#59;  oc++"]
    P2 --> P4["i++"]
    P3 --> P4
    P4 --> D1
    D1 -- No --> O1[/"Print Even numbers: even[0]...even[ec-1]"/]
    O1 --> O2[/"Print Odd numbers: odd[0]...odd[oc-1]"/]
    O2 --> E([END])

    style S fill:#166534,stroke:#4ade80,color:#fff
    style E fill:#166534,stroke:#4ade80,color:#fff
