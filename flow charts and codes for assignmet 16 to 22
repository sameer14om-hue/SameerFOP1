<!-- ==================== A19 ==================== -->
<div class="content" id="a19">
  <div class="asgn-header">
    <div class="asgn-badge">ASSIGNMENT NO. 19</div>
    <div class="asgn-title">Employee Structure in C</div>
    <div class="asgn-desc">struct EMPLOYEE with name, designation, gender, DOJ, salary — compute totals, gender split, salary filter, designation filter.</div>
  </div>
  <div class="cols">
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>C Code</span></div>
      <div class="card-body">
<pre><span class="pp">#include</span> <span class="str">&lt;stdio.h&gt;</span>
<span class="pp">#include</span> <span class="str">&lt;string.h&gt;</span>

<span class="kw">struct</span> <span class="type">EMPLOYEE</span> {
    <span class="type">char</span>  name[<span class="num">50</span>];
    <span class="type">char</span>  designation[<span class="num">50</span>];
    <span class="type">char</span>  gender[<span class="num">10</span>];
    <span class="type">char</span>  doj[<span class="num">15</span>];
    <span class="type">float</span> salary;
};

<span class="type">int</span> <span class="fn">main</span>() {
    <span class="type">int</span> n, i, male = <span class="num">0</span>, female = <span class="num">0</span>;

    <span class="fn">printf</span>(<span class="str">"Enter number of employees: "</span>);
    <span class="fn">scanf</span>(<span class="str">"%d"</span>, &amp;n);

    <span class="kw">struct</span> <span class="type">EMPLOYEE</span> emp[n];

    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; n; i++) {
        <span class="fn">printf</span>(<span class="str">"\nEmployee %d:\n"</span>, i + <span class="num">1</span>);
        <span class="fn">printf</span>(<span class="str">"  Name        : "</span>); <span class="fn">scanf</span>(<span class="str">"%s"</span>, emp[i].name);
        <span class="fn">printf</span>(<span class="str">"  Designation : "</span>); <span class="fn">scanf</span>(<span class="str">"%s"</span>, emp[i].designation);
        <span class="fn">printf</span>(<span class="str">"  Gender      : "</span>); <span class="fn">scanf</span>(<span class="str">"%s"</span>, emp[i].gender);
        <span class="fn">printf</span>(<span class="str">"  Date of Joining: "</span>); <span class="fn">scanf</span>(<span class="str">"%s"</span>, emp[i].doj);
        <span class="fn">printf</span>(<span class="str">"  Salary      : "</span>); <span class="fn">scanf</span>(<span class="str">"%f"</span>, &amp;emp[i].salary);
        <span class="kw">if</span> (<span class="fn">strcmp</span>(emp[i].gender, <span class="str">"Male"</span>) == <span class="num">0</span>) male++;
        <span class="kw">else</span> female++;
    }

    <span class="fn">printf</span>(<span class="str">"\nTotal employees   = %d\n"</span>, n);
    <span class="fn">printf</span>(<span class="str">"Male employees    = %d\n"</span>, male);
    <span class="fn">printf</span>(<span class="str">"Female employees  = %d\n"</span>, female);

    <span class="fn">printf</span>(<span class="str">"\nEmployees with salary &gt; 10000:\n"</span>);
    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; n; i++)
        <span class="kw">if</span> (emp[i].salary &gt; <span class="num">10000</span>)
            <span class="fn">printf</span>(<span class="str">"  %s (%.2f)\n"</span>, emp[i].name, emp[i].salary);

    <span class="fn">printf</span>(<span class="str">"\nEmployees with designation 'AsstManager':\n"</span>);
    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; n; i++)
        <span class="kw">if</span> (<span class="fn">strcmp</span>(emp[i].designation, <span class="str">"AsstManager"</span>) == <span class="num">0</span>)
            <span class="fn">printf</span>(<span class="str">"  %s\n"</span>, emp[i].name);

    <span class="kw">return</span> <span class="num">0</span>;
}</pre>
