  </div>
</div>

<script>
mermaid.initialize({
  startOnLoad: true,
  theme: 'dark',
  flowchart: { curve: 'linear', padding: 24, useMaxWidth: true },
  themeVariables: {
    primaryColor: '#1e293b',
    primaryTextColor: '#e2e8f0',
    primaryBorderColor: '#4ade80',
    lineColor: '#4ade80',
    secondaryColor: '#0f172a',
    edgeLabelBackground: '#181c25',
    fontFamily: 'Sora, sans-serif',
    fontSize: '14px'
  }
});

function show(num, tab) {
  document.querySelectorAll('.content').forEach(c => c.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('a' + num).classList.add('active');
  tab.classList.add('active');
}
</script>
