<div class="content" id="a20">
  <div class="asgn-header">
    <div class="asgn-badge">ASSIGNMENT NO. 20</div>
    <div class="asgn-title">Swap Two Numbers — With &amp; Without Pointers</div>
    <div class="asgn-desc">Call by Value: original unchanged. Call by Reference (pointers): original is modified directly in memory.</div>
  </div>
  <div class="cols">
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>C Code</span></div>
      <div class="card-body">
<pre><span class="pp">#include</span> <span class="str">&lt;stdio.h&gt;</span>

<span class="cmt">/* Call by Value — only local copies are swapped */</span>
<span class="type">void</span> <span class="fn">swapWithoutPointer</span>(<span class="type">int</span> a, <span class="type">int</span> b) {
    <span class="type">int</span> temp = a;
    a = b;
    b = temp;
    <span class="fn">printf</span>(<span class="str">"Inside function: a=%d, b=%d\n"</span>, a, b);
}

<span class="cmt">/* Call by Reference — original variables are changed */</span>
<span class="type">void</span> <span class="fn">swapWithPointer</span>(<span class="type">int</span> *a, <span class="type">int</span> *b) {
    <span class="type">int</span> temp = *a;
    *a = *b;
    *b = temp;
}

<span class="type">int</span> <span class="fn">main</span>() {
    <span class="type">int</span> a, b;
    <span class="fn">printf</span>(<span class="str">"Enter two numbers: "</span>);
    <span class="fn">scanf</span>(<span class="str">"%d %d"</span>, &amp;a, &amp;b);

    <span class="fn">printf</span>(<span class="str">"\n-- Without Pointers (Call by Value) --\n"</span>);
    <span class="fn">swapWithoutPointer</span>(a, b);
    <span class="fn">printf</span>(<span class="str">"In main: a=%d, b=%d  (unchanged)\n"</span>, a, b);

    <span class="fn">printf</span>(<span class="str">"\n-- With Pointers (Call by Reference) --\n"</span>);
    <span class="fn">swapWithPointer</span>(&amp;a, &amp;b);
    <span class="fn">printf</span>(<span class="str">"After swap: a=%d, b=%d\n"</span>, a, b);

    <span class="kw">return</span> <span class="num">0</span>;
}</pre>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="dot dot-b"></div><span>Sample I/O</span></div>
      <div class="card-body">
        <div class="output-box">
Enter two numbers: 10 20<br><br>
-- Without Pointers --<br>
Inside function: a=20, b=10<br>
In main: a=10, b=20 (unchanged)<br><br>
-- With Pointers --<br>
After swap: a=20, b=10
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="dot dot-p"></div><span>Concept Comparison</span></div>
      <div class="card-body">
        <div class="info-grid">
          <div class="info-item"><div class="info-label">Call by Value</div><div class="info-val">Copy of variable passed — original safe</div></div>
          <div class="info-item"><div class="info-label">Call by Reference</div><div class="info-val">Address passed — original is modified</div></div>
          <div class="info-item"><div class="info-label">*a</div><div class="info-val">Value at address a</div></div>
          <div class="info-item"><div class="info-label">&amp;a</div><div class="info-val">Memory address of variable a</div></div>
        </div>
      </div>
    </div>
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>Flowchart</span></div>
      <div class="card-body">
        <div class="mermaid-wrap">
          <div class="mermaid">
flowchart TD
    S([START]) --> I1[/"Input a, b"/]
    I1 --> P1["Call swapWithoutPointer(a, b) — passes copies"]
    P1 --> P2["Inside fn: temp=a&#59; a=b&#59; b=temp  — local swap only"]
    P2 --> O1[/"Print inside fn: a and b appear swapped"/]
    O1 --> O2[/"Print in main: a and b are UNCHANGED — call by value had no effect"/]
    O2 --> P3["Call swapWithPointer(&a, &b) — passes addresses"]
    P3 --> P4["Inside fn: temp=*a&#59; *a=*b&#59; *b=temp  — actual memory modified"]
    P4 --> O3[/"Print in main: a and b are now SWAPPED"/]
    O3 --> E([END])

