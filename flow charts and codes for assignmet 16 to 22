<!-- ==================== A17 ==================== -->
<div class="content" id="a17">
  <div class="asgn-header">
    <div class="asgn-badge">ASSIGNMENT NO. 17</div>
    <div class="asgn-title">Sum of Sine Series (Taylor Expansion)</div>
    <div class="asgn-desc">sin(x) = x − x³/3! + x⁵/5! − x⁷/7! + … Compute up to N terms for user-given x (radians).</div>
  </div>
  <div class="cols">
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>C Code</span></div>
      <div class="card-body">
<pre><span class="pp">#include</span> <span class="str">&lt;stdio.h&gt;</span>
<span class="pp">#include</span> <span class="str">&lt;math.h&gt;</span>

<span class="type">int</span> <span class="fn">main</span>() {
    <span class="type">double</span> x, sum = <span class="num">0.0</span>, term;
    <span class="type">int</span> n, i, j, power;
    <span class="type">long</span> <span class="type">long</span> fact;

    <span class="fn">printf</span>(<span class="str">"Enter value of x (in radians): "</span>);
    <span class="fn">scanf</span>(<span class="str">"%lf"</span>, &amp;x);
    <span class="fn">printf</span>(<span class="str">"Enter number of terms: "</span>);
    <span class="fn">scanf</span>(<span class="str">"%d"</span>, &amp;n);

    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; n; i++) {
        power = <span class="num">2</span> * i + <span class="num">1</span>;   <span class="cmt">// 1, 3, 5, 7 ...</span>
        fact  = <span class="num">1</span>;
        <span class="kw">for</span> (j = <span class="num">1</span>; j &lt;= power; j++)
            fact *= j;
        term = <span class="fn">pow</span>(x, power) / (<span class="type">double</span>)fact;
        <span class="kw">if</span> (i % <span class="num">2</span> == <span class="num">0</span>) sum += term;
        <span class="kw">else</span>            sum -= term;
    }

    <span class="fn">printf</span>(<span class="str">"Sum of sine series = %lf\n"</span>, sum);
    <span class="kw">return</span> <span class="num">0</span>;
}
<span class="cmt">/* Compile: gcc a17.c -o a17 -lm */</span></pre>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="dot dot-b"></div><span>Sample I/O</span></div>
      <div class="card-body">
        <div class="output-box">
<span class="output-prompt">Input:</span><br>
Enter x (in radians): 1<br>
Enter number of terms: 5<br><br>
<span class="output-prompt">Output:</span><br>
Sum of sine series = 0.841471
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="dot dot-p"></div><span>Formula</span></div>
      <div class="card-body">
        <div class="info-item" style="margin-bottom:8px"><div class="info-label">Taylor Series</div><div class="info-val">sin(x) = x - x³/3! + x⁵/5! - ...</div></div>
        <div class="info-item" style="margin-bottom:8px"><div class="info-label">i-th term</div><div class="info-val">(-1)^i × x^(2i+1) / (2i+1)!</div></div>
        <div class="info-item"><div class="info-label">Compile</div><div class="info-val">gcc a17.c -o a17 -lm</div></div>
      </div>
    </div>
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>Flowchart</span></div>
      <div class="card-body">
        <div class="mermaid-wrap">
          <div class="mermaid">
flowchart TD
    S([START]) --> I1[/"Input x, n"/]
    I1 --> P1["sum = 0.0,  i = 0"]
    P1 --> D1{"i &lt; n ?"}
    D1 -- Yes --> P2["power = 2 × i + 1"]
    P2 --> P3["Compute fact = power!  via inner loop"]
    P3 --> P4["term = pow(x, power) / fact"]
    P4 --> D2{"i % 2 == 0 ?"}
    D2 -- "Yes (add)" --> P5["sum = sum + term"]
    D2 -- "No (subtract)" --> P6["sum = sum - term"]
    P5 --> P7["i++"]
    P6 --> P7
    P7 --> D1
    D1 -- No --> O1[/"Print sum"/]
    O1 --> E([END])

    style S fill:#166534,stroke:#4ade80,color:#fff
    style E fill:#166534,stroke:#4ade80,color:#fff
    style D1 fill:#312e81,stroke:#a78bfa,color:#fff
    style D2 fill:#312e81,stroke:#a78bfa,color:#fff
    style I1 fill:#0c4a6e,stroke:#38bdf8,color:#fff
    style O1 fill:#0c4a6e,stroke:#38bdf8,color:#fff
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ==================== A18 ==================== -->
<div class="content" id="a18">
  <div class="asgn-header">
    <div class="asgn-badge">ASSIGNMENT NO. 18</div>
    <div class="asgn-title">String Operations in C</div>
    <div class="asgn-desc">Perform: (i) length, (ii) reversal, (iii) equality check, (iv) palindrome check, (v) substring check.</div>
  </div>
  <div class="cols">
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>C Code</span></div>
      <div class="card-body">
<pre><span class="pp">#include</span> <span class="str">&lt;stdio.h&gt;</span>
<span class="pp">#include</span> <span class="str">&lt;string.h&gt;</span>

<span class="type">int</span> <span class="fn">main</span>() {
    <span class="type">char</span> s1[<span class="num">100</span>], s2[<span class="num">100</span>], rev[<span class="num">100</span>];
    <span class="type">int</span>  len, i;

    <span class="fn">printf</span>(<span class="str">"Enter a string: "</span>);
    <span class="fn">scanf</span>(<span class="str">"%s"</span>, s1);

    <span class="cmt">/* i) Length */</span>
    len = <span class="fn">strlen</span>(s1);
    <span class="fn">printf</span>(<span class="str">"Length of string = %d\n"</span>, len);

    <span class="cmt">/* ii) Reversal */</span>
    <span class="kw">for</span> (i = <span class="num">0</span>; i &lt; len; i++)
        rev[i] = s1[len - <span class="num">1</span> - i];
    rev[len] = <span class="str">'\0'</span>;
    <span class="fn">printf</span>(<span class="str">"Reversed string = %s\n"</span>, rev);

    <span class="cmt">/* iv) Palindrome */</span>
    <span class="kw">if</span> (<span class="fn">strcmp</span>(s1, rev) == <span class="num">0</span>)
        <span class="fn">printf</span>(<span class="str">"The string is a Palindrome\n"</span>);
    <span class="kw">else</span>
        <span class="fn">printf</span>(<span class="str">"The string is NOT a Palindrome\n"</span>);

    <span class="cmt">/* iii) Equality check */</span>
    <span class="fn">printf</span>(<span class="str">"Enter another string for equality check: "</span>);
    <span class="fn">scanf</span>(<span class="str">"%s"</span>, s2);
    <span class="kw">if</span> (<span class="fn">strcmp</span>(s1, s2) == <span class="num">0</span>)
        <span class="fn">printf</span>(<span class="str">"Strings are equal\n"</span>);
    <span class="kw">else</span>
        <span class="fn">printf</span>(<span class="str">"Strings are not equal\n"</span>);

    <span class="cmt">/* v) Substring check */</span>
    <span class="kw">if</span> (<span class="fn">strstr</span>(s1, s2) != <span class="num">NULL</span>)
        <span class="fn">printf</span>(<span class="str">"Substring found in main string\n"</span>);
    <span class="kw">else</span>
        <span class="fn">printf</span>(<span class="str">"Substring NOT found in main string\n"</span>);

    <span class="kw">return</span> <span class="num">0</span>;
}</pre>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="dot dot-b"></div><span>Sample I/O</span></div>
      <div class="card-body">
        <div class="output-box">
Enter a string: madam<br>
Length of string = 5<br>
Reversed string = madam<br>
The string is a Palindrome<br><br>
Enter another string: mad<br>
Strings are not equal<br>
Substring found in main string
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="dot dot-p"></div><span>Functions Used</span></div>
      <div class="card-body">
        <div class="info-grid">
          <div class="info-item"><div class="info-label">strlen(s)</div><div class="info-val">Count of chars before '\0'</div></div>
          <div class="info-item"><div class="info-label">strcmp(a,b)</div><div class="info-val">0 if equal, else non-zero</div></div>
          <div class="info-item"><div class="info-label">strstr(s,sub)</div><div class="info-val">Pointer if found, else NULL</div></div>
          <div class="info-item"><div class="info-label">Reversal</div><div class="info-val">rev[i] = s1[len-1-i] in loop</div></div>
        </div>
      </div>
    </div>
    <div class="card full">
      <div class="card-header"><div class="dot dot-g"></div><span>Flowchart</span></div>
      <div class="card-body">
        <div class="mermaid-wrap">
          <div class="mermaid">
flowchart TD
    S([START]) --> I1[/Input s1/]
    I1 --> P1["len = strlen(s1)"]
    P1 --> O1[/"Print: Length = len"/]
    O1 --> P2["Build rev[]: loop — rev[i] = s1[len-1-i]"]
    P2 --> O2[/"Print: Reversed = rev"/]
    O2 --> D1{"strcmp(s1, rev) == 0 ?"}
    D1 -- Yes --> O3[/"Print: String is a Palindrome"/]
    D1 -- No  --> O4[/"Print: NOT a Palindrome"/]
    O3 --> I2[/Input s2/]
    O4 --> I2
    I2 --> D2{"strcmp(s1, s2) == 0 ?"}
    D2 -- Yes --> O5[/"Print: Strings are Equal"/]
    D2 -- No  --> O6[/"Print: Strings are NOT Equal"/]
    O5 --> D3{"strstr(s1, s2) != NULL ?"}
    O6 --> D3
    D3 -- Yes --> O7[/"Print: Substring Found"/]
    D3 -- No  --> O8[/"Print: Substring NOT Found"/]
    O7 --> E([END])
    O8 --> E

